# The base URL of your backend server. For local development, this typically points to localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# These are your Firebase project's web app configuration keys.
# You can find these in the Firebase Console:
# Go to Project Settings > General > Your apps > Web app > Firebase SDK snippet > Config.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
